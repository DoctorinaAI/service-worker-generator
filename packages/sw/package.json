{
  "name": "@sw/scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build -c vite.config.sw.ts && vite build -c vite.config.bootstrap.ts",
    "build:sw": "vite build -c vite.config.sw.ts",
    "build:bootstrap": "vite build -c vite.config.bootstrap.ts",
    "dev": "vite build -c vite.config.sw.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^3.1.0"
  }
}
