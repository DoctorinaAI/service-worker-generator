{
  "name": "@sw/scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build -c vite.config.sw.ts && vite build -c vite.config.bootstrap.ts",
    "build:sw": "vite build -c vite.config.sw.ts",
    "build:bootstrap": "vite build -c vite.config.bootstrap.ts",
    "dev": "vite build -c vite.config.sw.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.4"
  }
}
